# Django Backend Environment Variables

DEBUG=0
DJANGO_SECRET_KEY=dev-secret-key-change-me-in-production
ALLOWED_HOSTS=spywords.onrender.com
CORS_ALLOWED_ORIGINS=https://spywords.vercel.app

# Database (optional - uses SQLite by default)
# DATABASE_URL=postgres://user:password@localhost:5432/codenames
# POSTGRES_DB=codenames
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Redis Configuration
REDIS_URL=redis://127.0.0.1:6379/1

# For quick dev without Redis, set this to 1
USE_IN_MEMORY_CHANNEL_LAYER=0
